rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: profiles
    // Fields: uid, email, displayName, photoURL, role, createdAt, updatedAt, onboardingCompleted, settings
    //
    // Collection: leads
    // Fields: ownerId, username, fullName, bio, followers, category, contactEmail, status, tags, createdAt, updatedAt, aiScore, aiReasoning
    //
    // Collection: tasks
    // Fields: ownerId, leadId, title, priority, dueDate, completed, createdAt
    //
    // Collection: messages
    // Fields: ownerId, leadId, content, type, createdAt
    //
    // Collection: automationRules
    // Fields: ownerId, name, trigger, action, enabled, createdAt
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.ownerId;
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // ===============================================================
    // Profile Rules
    // ===============================================================
    match /profiles/{userId} {
      allow read: if isOwner(userId);
      allow create, update: if isOwner(userId) && 
        (request.resource.data.updatedAt is string || request.resource.data.createdAt is string);
    }

    // ===============================================================
    // Lead Rules
    // ===============================================================
    match /leads/{leadId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && 
        request.resource.data.ownerId == request.auth.uid;
      allow update: if isDocOwner() && 
        request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isDocOwner();
    }

    // ===============================================================
    // Task Rules
    // ===============================================================
    match /tasks/{taskId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && 
        request.resource.data.ownerId == request.auth.uid;
      allow update: if isDocOwner() && 
        request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isDocOwner();
    }

    // ===============================================================
    // Message Rules
    // ===============================================================
    match /messages/{messageId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && 
        request.resource.data.ownerId == request.auth.uid;
      allow delete: if isDocOwner();
    }

    // ===============================================================
    // Automation Rule Rules
    // ===============================================================
    match /automationRules/{ruleId} {
      allow read: if isDocOwner();
      allow create: if isAuthenticated() && 
        request.resource.data.ownerId == request.auth.uid;
      allow update: if isDocOwner() && 
        request.resource.data.ownerId == resource.data.ownerId;
      allow delete: if isDocOwner();
    }
  }
}
